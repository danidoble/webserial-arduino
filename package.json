{
  "name": "@danidoble/webserial-arduino",
  "type": "module",
  "version": "1.0.1",
  "description": "A starter for creating a TypeScript package.",
  "author": "Danidoble <ddanidoble@gmail.com>",
  "license": "GPL-3.0-only",
  "homepage": "https://github.com/danidoble/webserial-arduino#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danidoble/webserial-arduino.git"
  },
  "bugs": {
    "url": "https://github.com/danidoble/webserial-arduino/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "prettier --write ./src/**/*.ts && tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint ./src/**/*.ts ./tests/**/*.ts",
    "format": "prettier --write ./src/ ./tests/ ./README.md ./package.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "bumpp": "^11.0.1",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "prettier": "3.8.3",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4",
    "webserial-core": "^2.1.0"
  },
  "peerDependencies": {
    "webserial-core": "^2.0.3"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts"
}
